# Firebase Configuration
# Get these values from your Firebase Console:
# Project Settings > General > Your apps > Web app

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# GitHub Configuration (for Commits page)
# These are optional - if not set, the Commits page will show an error
VITE_GITHUB_OWNER=your-github-username
VITE_GITHUB_REPO=your-repo-name
VITE_GITHUB_BRANCH=master

# Agent Configuration
# Path to the target repo the Architect agent analyzes
AGENT_WORKING_DIR=/path/to/agentic-test-client

# Monitor Agent — GitHub repo to watch for merged PRs
# GITHUB_OWNER and GITHUB_REPO can reuse the same values as VITE_GITHUB_OWNER/REPO
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
GITHUB_TOKEN=your-github-pat   # optional for public repos, required for private
MONITOR_POLL_INTERVAL=60000    # ms between checks (default: 60s)
